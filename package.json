{
  "name": "ytdlp-api-server",
  "version": "2.2.0",
  "description": "24/7 YT-DLP API with PO Token bypass, custom quality/conversion via ffmpeg",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ytdlp-api",
    "pm2:restart": "pm2 restart ytdlp-api",
