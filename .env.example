# =================== Server ===================
PORT=3000
NODE_ENV=production

# =================== Binaries ===================
# yt-dlp binary path (leave empty to use from PATH)
YT_DLP_PATH=yt-dlp

# FFmpeg binary path (leave empty to auto-detect)
FFMPEG_PATH=

# =================== PO Token Provider ===================
# bgutil-ytdlp-pot-provider
#
# Set POTOKEN_PROVIDER_AUTO_START=true ONLY if bgutil is reachable at
# POTOKEN_PROVIDER_URL (e.g. docker-compose with the bgutil sidecar, or a
# local install). The server will spawn the provider automatically and use
# it as a fallback when no stored token is available.
#
# Set POTOKEN_PROVIDER_AUTO_START=false for production deployments where
# tokens are pushed by an external system (GitHub Action, manual admin
# call, etc.). The server will only ever use the stored token; if it
# expires and no replacement has been pushed, downloads will fail loudly
# instead of trying to spawn a non-existent local provider binary.
#
# POTOKEN_PROVIDER_URL is still required as the yt-dlp extractor base URL
# for the fallback code path, but is unused when autoStart is false and a
# stored token is present.
POTOKEN_PROVIDER_URL=http://127.0.0.1:4416
POTOKEN_PROVIDER_AUTO_START=true

# =================== Storage ===================
DATA_DIR=./data
COOKIES_FILE=./data/cookies.txt
DOWNLOAD_DIR=./downloads

# =================== Download Limits ===================
# Refuse videos longer than this (seconds). 21600 = 6 hours
MAX_DOWNLOAD_DURATION_SEC=21600
# Per-operation timeout in milliseconds. 1800000 = 30 minutes
DOWNLOAD_TIMEOUT_MS=1800000

# =================== Optional ===================
# Shared secret for GitHub Action webhook verification
GITHUB_WEBHOOK_SECRET=

# =================== Metadata Embedding ===================
# Auto-embed title / artist / uploader / description / tags / thumbnail
# cover art + Developer Credit into every download (audio + video) using
# ffmpeg. Lossless (ffmpeg -c copy, no re-encode). Set to 'false' to
# disable globally; per-request override with ?embed=false on any
# download endpoint.
EMBED_METADATA=true
DEVELOPER_CREDIT=Mohammad Kobir Shah
DEVELOPER_CREDIT_URL=https://github.com/MohammadKobirShah
API_NAME=YT-DLP API Server
API_VERSION=2.2.0

